# ── Webinti Town self-host — copie ce fichier en .env et remplis-le ──
# cp .env.example .env      (ou lance ./install.sh qui le génère pour toi)

# Domaine de l'application (1 enregistrement DNS A pointant sur ce serveur)
DOMAIN=town.exemple.com

# Compte administrateur/hôte de l'espace (email du compte qui devient admin)
HOST_EMAIL=admin@exemple.com

# ── Licence Webinti (fournie par Webinti après souscription Enterprise) ──
LICENSE_KEY=LIC-XXXX-YYYY
LICENSE_SERVER_URL=https://licenses.webinti.com

# ── PocketBase : identifiants du 1er compte admin (à créer au 1er démarrage) ──
POCKETBASE_ADMIN_EMAIL=admin@exemple.com
POCKETBASE_ADMIN_PASSWORD=change-moi-svp

# ══════════════════════════════════════════════════════════════════════════
#  AUDIO / VIDÉO — Mode 1 (PAR DÉFAUT) : LiveKit Cloud  ← le plus simple
#  Crée un projet gratuit sur https://cloud.livekit.io et colle ses 3 valeurs.
# ══════════════════════════════════════════════════════════════════════════
LIVEKIT_URL=wss://ton-projet.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=secret-livekit-cloud

# ══════════════════════════════════════════════════════════════════════════
#  AUDIO / VIDÉO — Mode 2 (AVANCÉ) : SFU auto-hébergé dans le bundle
#  Décommente ce bloc, crée un 2e DNS A (livekit.exemple.com), ouvre 7881/tcp
#  & 7882/udp, et invente une paire clé/secret (openssl rand -hex 16 / 32).
# ══════════════════════════════════════════════════════════════════════════
# LIVEKIT_DOMAIN=livekit.exemple.com
# LIVEKIT_URL=wss://livekit.exemple.com
# LIVEKIT_API_KEY=change-moi-cle
# LIVEKIT_API_SECRET=change-moi-secret-long
# CADDYFILE=Caddyfile.local
# COMPOSE_PROFILES=local-livekit

# ── IA d'accueil (facultatif) : laisse vide pour désactiver ──
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini
