# Webinti Town — production .env example.
# Copy to .env at the project root on the VPS and replace every <changeme>.

PORT=3001
NODE_ENV=production

# CORS — must match the URL the browser uses to load the site.
CLIENT_ORIGIN=https://live.webinti.com

# LiveKit
# The URL the BROWSER will use to reach LiveKit (proxied by nginx).
LIVEKIT_URL=wss://live.webinti.com/livekit
# Must match keys.<API_KEY>: <API_SECRET> in livekit.yaml
LIVEKIT_API_KEY=webinti
# Generate with: openssl rand -hex 32
LIVEKIT_API_SECRET=<changeme-32-chars-min>

# Room defaults
DEFAULT_MAX_CAPACITY=25
PROXIMITY_RADIUS=5
PROXIMITY_FULL_VOLUME=3
TICK_RATE=20
PROXIMITY_CHECK_RATE=4

# Host token — anyone hitting ?host=<this-value> becomes the room host.
# Generate with: openssl rand -hex 24
HOST_TOKEN=<changeme-strong-secret>
