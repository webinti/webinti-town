PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DATABASE_URL=postgresql://webintispace:password@localhost:5432/webintispace

LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

DEFAULT_MAX_CAPACITY=25
PROXIMITY_RADIUS=5
PROXIMITY_FULL_VOLUME=3
TICK_RATE=20
PROXIMITY_CHECK_RATE=4

# Agent IA d'accueil (la secrétaire « Inès »). Sans clé, la fonctionnalité est
# simplement inactive — le reste de l'app n'est pas affecté.
# Moteur compatible OpenAI : OpenRouter par défaut (surchargeable pour un Hermes maison).
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini
