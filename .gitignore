node_modules/
dist/
build/
.env
.env.local
*.log
.DS_Store
.vite/
coverage/
pgdata/

# Kanban persistent data — not committed (one file per room)
server/data/*.json

# Upload files — stored on disk, not committed
server/data/uploads/*
!server/data/uploads/.gitkeep

# Zips sources LimeZu (volumineux) — seuls les PNG extraits sont versionnés
client/public/assets/*.zip

# Map générée par prepare-map. Ces artefacts SONT versionnés : le déploiement
# prod est un `git pull + build` sur le VPS, qui ne peut pas lancer prepare-map
# (sources LimeZu absentes). Régénère-les sur le Mac via `npm run prepare-map`
# après chaque édition de la map dans Tiled, puis commit.

# Tiled tileset scratch files (chemins absolus machine-spécifiques vers ~/Downloads)
client/public/maps/Room_Builder_32x32.tsx
client/public/maps/Tv_Studio_Design_preview_32x32.tsx

# Caches de build / réglages locaux (régénérés, ne pas versionner — cassaient les déploiements)
client/tsconfig.tsbuildinfo
.claude/settings.local.json

# Système de licence self-host — SECRETS, ne JAMAIS committer :
#   • keys/private-key.pem : signe les jetons ; qui l'a peut fabriquer des licences
#   • licenses.json        : registre des clients/abonnements
license-server/keys/
license-server/licenses.json
